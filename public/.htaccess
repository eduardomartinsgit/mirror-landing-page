# .htaccess do Mirror (landing estatico) para Apache / cPanel (HostGator).
# Fica em public/ e e copiado para out/ no build, indo parar no public_html.
#
# ATENCAO: o bloco de "forcar HTTPS" so deve ficar ativo DEPOIS que o
# certificado SSL estiver emitido para o dominio. Antes do SSL, ele causa
# loop/erro. Ative o SSL no cPanel primeiro.

# ---- Forcar HTTPS + dominio canonico (non-www) ----
# Canonico escolhido: usemirror.com.br (sem www). HTTPS e www->non-www num
# unico redirect 301. Para preferir COM www, comente este bloco e use o
# bloco alternativo logo abaixo.
RewriteEngine On
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^ https://usemirror.com.br%{REQUEST_URI} [L,R=301]

# ---- Alternativa: forcar COM www (deixe comentado se usar o de cima) ----
# RewriteCond %{HTTPS} off [OR]
# RewriteCond %{HTTP_HOST} !^www\. [NC]
# RewriteRule ^ https://www.usemirror.com.br%{REQUEST_URI} [L,R=301]

# ---- URLs limpas: sem barra final e sem .html ----
Options -MultiViews -Indexes
# Remover a barra final (exceto na raiz)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [L,R=301]
# Servir o .html correspondente sem mostrar a extensao
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# ---- Pagina 404 (gerada pelo Next export) ----
ErrorDocument 404 /404.html

# ---- Compressao ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

# ---- Cache ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
</IfModule>

<IfModule mod_headers.c>
  # Assets do Next sao hasheados (imutaveis): cache agressivo.
  <FilesMatch "\.(js|css|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML sempre revalida, para o deploy novo aparecer na hora.
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  # HSTS: so faz efeito sobre HTTPS (ative o SSL antes). Sem "preload" por
  # enquanto; so adicione preload depois que TODOS os subdominios estiverem
  # em HTTPS e voce submeter em hstspreload.org (compromisso forte).
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains"

  # ---- Anti-clickjacking + CSP ----
  Header always set X-Frame-Options "DENY"
  # CSP montada a partir das dependencias reais do landing:
  #  - script/style 'unsafe-inline': o Next (export estatico) injeta scripts de
  #    hidratacao inline e nao ha nonce em build estatico.
  #  - fontes: next/font self-hospeda (vem de 'self', sem Google Fonts).
  #  - connect-src: ipapi.co (geo-gate) e *.supabase.co (formulario da lista).
  # Se adicionar analytics/pixel/iframe no futuro, libere o dominio aqui.
  # TESTE no DevTools (console mostra violacoes) antes de confiar. Para testar
  # sem quebrar, troque por Content-Security-Policy-Report-Only.
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' https://ipapi.co https://*.supabase.co; upgrade-insecure-requests"

  # ---- Permissions-Policy: desliga tudo que o landing nao usa ----
  Header always set Permissions-Policy "accelerometer=(), autoplay=(), camera=(), cross-origin-isolated=(), display-capture=(), encrypted-media=(), fullscreen=(self), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(), publickey-credentials-get=(), screen-wake-lock=(), usb=(), web-share=(), browsing-topics=()"

  # ---- Isolamento de origem cruzada (mitiga Spectre; bloqueia hotlink) ----
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"
  # COEP require-corp da isolamento total, mas pode quebrar recursos de
  # terceiros. Opcional; ative so se precisar de crossOriginIsolated.
  # Header always set Cross-Origin-Embedder-Policy "require-corp"

  # ---- Extras + esconder tecnologia ----
  Header always set X-Permitted-Cross-Domain-Policies "none"
  Header always set X-DNS-Prefetch-Control "off"
  Header always unset X-Powered-By
  Header always unset Server
</IfModule>

# ---- Bloquear arquivos sensiveis (.env, source maps, dotfiles de VCS) ----
<FilesMatch "(^\.env|\.env\.|\.map$|^\.git|^\.hg|^\.svn)">
  Require all denied
</FilesMatch>
